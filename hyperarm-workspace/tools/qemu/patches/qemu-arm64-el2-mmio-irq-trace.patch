diff --git a/target/arm/helper.c b/target/arm/helper.c
index 9ff266a..7976a04 100644
--- a/target/arm/helper.c
+++ b/target/arm/helper.c
@@ -11158,6 +11158,36 @@ static void arm_cpu_do_interrupt_aarch64(CPUState *cs)
          * FEAT_DoubleFault allows synchronous external aborts taken to EL3
          * to be taken to the SError vector entrypoint.
          */
+        if (cs->exception_index == EXCP_DATA_ABORT && new_el == 2 && cur_el == 1) {
+            uint64_t far = env->exception.vaddress;
+            uint64_t paddr = ((env->cp15.hpfar_el2 >> 4) << 12) | (far & 0xfff);
+            bool is_write = extract32(env->exception.syndrome, 6, 1);
+            int rt = extract32(env->exception.syndrome, 16, 5);
+            int sas = extract32(env->exception.syndrome, 22, 2);
+            int size = 1 << sas;
+
+            if (is_write) {
+                uint64_t value = env->xregs[rt];
+                switch (size) {
+                case 1:
+                    value &= 0xff;
+                    break;
+                case 2:
+                    value &= 0xffff;
+                    break;
+                case 4:
+                    value &= 0xffffffffu;
+                    break;
+                default:
+                    break;
+                }
+                trace_arm_mmio_el2_from_el1_write(cs->cpu_index, paddr, size,
+                                                  rt, value);
+            } else {
+                trace_arm_mmio_el2_from_el1_read_request(cs->cpu_index, paddr,
+                                                         size, rt);
+            }
+        }
         if (new_el == 3 && (env->cp15.scr_el3 & SCR_EASE) &&
             syndrome_is_sync_extabt(env->exception.syndrome)) {
             addr += 0x180;
@@ -11214,13 +11244,16 @@ static void arm_cpu_do_interrupt_aarch64(CPUState *cs)
         break;
     case EXCP_IRQ:
     case EXCP_VIRQ:
+        trace_arm_irq(cs->cpu_index, cs->exception_index, cur_el, new_el);
         addr += 0x80;
         break;
     case EXCP_FIQ:
     case EXCP_VFIQ:
+        trace_arm_irq(cs->cpu_index, cs->exception_index, cur_el, new_el);
         addr += 0x100;
         break;
     case EXCP_VSERR:
+        trace_arm_irq(cs->cpu_index, cs->exception_index, cur_el, new_el);
         addr += 0x180;
         /* Construct the SError syndrome from IDS and ISS fields. */
         env->exception.syndrome = syn_serror(env->cp15.vsesr_el2 & 0x1ffffff);
diff --git a/target/arm/tcg/helper-a64.c b/target/arm/tcg/helper-a64.c
index 8ad8462..50c51e8 100644
--- a/target/arm/tcg/helper-a64.c
+++ b/target/arm/tcg/helper-a64.c
@@ -33,6 +33,7 @@
 #include "qemu/int128.h"
 #include "qemu/atomic128.h"
 #include "fpu/softfloat.h"
+#include "trace.h"
 #include <zlib.h> /* For crc32 */
 
 /* C2.4.7 Multiply and divide */
@@ -809,6 +810,37 @@ void HELPER(exception_return)(CPUARMState *env, uint64_t new_pc)
         goto illegal_return;
     }
 
+    if (cur_el == 2 && new_el == 1) {
+        uint64_t esr = env->cp15.esr_el[2];
+        int ec = syn_get_ec(esr);
+
+        if (ec == EC_DATAABORT && extract32(esr, 24, 1) && !extract32(esr, 6, 1)) {
+            uint64_t far = env->cp15.far_el[2];
+            uint64_t paddr = ((env->cp15.hpfar_el2 >> 4) << 12) | (far & 0xfff);
+            int rt = extract32(esr, 16, 5);
+            int sas = extract32(esr, 22, 2);
+            int size = 1 << sas;
+            uint64_t value = env->xregs[rt];
+
+            switch (size) {
+            case 1:
+                value &= 0xff;
+                break;
+            case 2:
+                value &= 0xffff;
+                break;
+            case 4:
+                value &= 0xffffffffu;
+                break;
+            default:
+                break;
+            }
+
+            trace_arm_mmio_el2_from_el1_read_return(env_cpu(env)->cpu_index,
+                                                    paddr, size, rt, value);
+        }
+    }
+
     qemu_mutex_lock_iothread();
     arm_call_pre_el_change_hook(env_archcpu(env));
     qemu_mutex_unlock_iothread();
diff --git a/target/arm/trace-events b/target/arm/trace-events
index 48cc051..019908e 100644
--- a/target/arm/trace-events
+++ b/target/arm/trace-events
@@ -9,6 +9,10 @@ arm_gt_ctl_write(int timer, uint64_t value) "gt_ctl_write: timer %d value 0x%" P
 arm_gt_imask_toggle(int timer) "gt_ctl_write: timer %d IMASK toggle"
 arm_gt_cntvoff_write(uint64_t value) "gt_cntvoff_write: value 0x%" PRIx64
 arm_gt_update_irq(int timer, int irqstate) "gt_update_irq: timer %d irqstate %d"
+arm_irq(int cpu_index, int excp, int cur_el, int new_el) "cpu=%d excp=%d cur_el=%d new_el=%d"
+arm_mmio_el2_from_el1_write(int cpu_index, uint64_t paddr, int size, int rt, uint64_t value) "cpu=%d EL2<-EL1 MMIO W paddr=0x%" PRIx64 " size=%d rt=%d value=0x%" PRIx64
+arm_mmio_el2_from_el1_read_request(int cpu_index, uint64_t paddr, int size, int rt) "cpu=%d EL2<-EL1 MMIO R paddr=0x%" PRIx64 " size=%d rt=%d"
+arm_mmio_el2_from_el1_read_return(int cpu_index, uint64_t paddr, int size, int rt, uint64_t value) "cpu=%d EL2->EL1 MMIO R paddr=0x%" PRIx64 " size=%d rt=%d value=0x%" PRIx64
 
 # kvm.c
 kvm_arm_fixup_msi_route(uint64_t iova, uint64_t gpa) "MSI iova = 0x%"PRIx64" is translated into 0x%"PRIx64
