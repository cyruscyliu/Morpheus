--- a/examples/virtio/Makefile
+++ b/examples/virtio/Makefile
@@ -30,7 +30,7 @@
 	export BLK_DRIVER := virtio
 	export ETH_DRIVER := virtio
 	export CPU := cortex-a53
-	export GIC_DT_OVERLAY := gic_v2_overlay.dts
+	export GIC_DT_OVERLAY := gic_v3_overlay.dts
 	QEMU := qemu-system-aarch64
 
 	export BLK_NUM_PART = 1
diff --git a/examples/virtio/virtio.mk b/examples/virtio/virtio.mk
--- a/examples/virtio/virtio.mk
+++ b/examples/virtio/virtio.mk
@@ -3,7 +3,8 @@
 #
 # SPDX-License-Identifier: BSD-2-Clause
 #
-QEMU := qemu-system-aarch64
+QEMU ?= qemu-system-aarch64
+QEMU_TRACE_ARGS ?=
 PYTHON ?= python3
 
 LIBVMM_DOWNLOADS := https://trustworthy.systems/Downloads/libvmm/images/
@@ -177,14 +178,15 @@ qemu: $(IMAGE_FILE) blk_storage
 	[ ${MICROKIT_BOARD} = qemu_virt_aarch64 ]
-	$(QEMU) -machine virt,virtualization=on,secure=off \
+	$(QEMU) -machine virt,virtualization=on,secure=off,gic-version=3 \
 			-cpu cortex-a53 \
 			-serial mon:stdio \
 			-device loader,file=$(IMAGE_FILE),addr=0x70000000,cpu-num=0 \
 			-m size=2G \
 			-nographic \
 			-global virtio-mmio.force-legacy=false \
 			-drive file=blk_storage,format=raw,if=none,id=drive0 \
 			-device virtio-blk-device,drive=drive0,id=virtblk0,num-queues=1 \
 			-device virtio-net-device,netdev=netdev0 \
-			-netdev user,id=netdev0,hostfwd=tcp::1236-:1236,hostfwd=tcp::1237-:1237,hostfwd=udp::1235-:1235 \
+			$(QEMU_TRACE_ARGS) \
+			-netdev user,id=netdev0 \
 
 clean::
 	$(RM) -f *.elf .depend* $
