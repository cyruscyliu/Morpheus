{
  "worktree": {
    "setup": [
      "pnpm install",
      "pnpm --filter @morpheus/app build",
      "pnpm run build:js-tools"
    ]
  },
  "scripts": {
    "hyperarm-check": {
      "command": "./bin/morpheus --config projects/hyperarm/morpheus.yaml config check --json"
    },
    "hyperarm-tools": {
      "command": "./bin/morpheus --config projects/hyperarm/morpheus.yaml tool list --json"
    },
    "o2p-check": {
      "command": "./bin/morpheus --config projects/o2p/morpheus.yaml config check --json"
    },
    "o2p-tools": {
      "command": "./bin/morpheus --config projects/o2p/morpheus.yaml tool list --json"
    },
    "runs-viewer": {
      "type": "service",
      "command": "cd apps/runs-viewer && pnpm dev -- --hostname 127.0.0.1 --port $PASEO_PORT"
    }
  }
}
