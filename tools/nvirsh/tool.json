{
  "name": "nvirsh",
  "runtime": "node",
  "cli-contract": "run,inspect,logs",
  "entry": "dist/index.js",
  "runGuard": {
    "scope": "workspace",
    "keyTemplate": "{target}:{runtime.provider.action}"
  },
  "config": {
    "fields": {
      "mode": { "aliases": ["mode"] },
      "path": { "aliases": ["path"], "path": true },
      "state-dir": { "aliases": ["state-dir", "stateDir"], "path": true },
      "target": { "aliases": ["target"] },
      "name": { "aliases": ["name"] },
      "board": { "aliases": ["board"] },
      "qemu": { "aliases": ["qemu"], "path": true },
      "microkit-sdk": { "aliases": ["microkit-sdk", "microkitSdk"], "path": true },
      "microkit-version": { "aliases": ["microkit-version", "microkitVersion"] },
      "microkit-config": { "aliases": ["microkit-config", "microkitConfig"] },
      "toolchain": { "aliases": ["toolchain"], "path": true },
      "libvmm-dir": { "aliases": ["libvmm-dir", "libvmmDir"], "path": true },
      "runtime-contract": { "aliases": ["runtime-contract", "runtimeContract"], "path": true },
      "runtime-action": { "aliases": ["runtime-action", "runtimeAction"] },
      "kernel": { "aliases": ["kernel"], "path": true },
      "initrd": { "aliases": ["initrd"], "path": true },
      "qemu-arg": { "aliases": ["qemu-arg", "qemu-args", "qemuArgs"], "repeatable": true },
      "attach": { "aliases": ["attach"], "boolean": true },
      "dependencies": { "aliases": ["dependencies"] }
    }
  },
  "inputs": {
    "run": {
      "dependencies": {
        "qemu": { "flag": "qemu" },
        "microkit-sdk": { "flag": "microkit-sdk" },
        "toolchain-bin-dir": { "flag": "toolchain" },
        "libvmm-dir": { "flag": "libvmm-dir" },
        "kernel": { "flag": "kernel" },
        "initrd": { "flag": "initrd" }
      },
      "config": {
        "runtime.provider": { "flag": "runtime-contract" }
      }
    }
  }
}
