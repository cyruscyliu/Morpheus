From 1e6c8e3f5c2b4d7e9a1b2c3d4e5f678901234567 Mon Sep 17 00:00:00 2001
From: Morpheus <morpheus@example.com>
Date: Thu, 23 Apr 2026 00:00:00 +0000
Subject: [PATCH] Add requirements.txt for virtio example python deps

The virtio example expects `sdfgen` 0.28.*. Provide a repo-local
`requirements.txt` so users and automation can install the expected python
dependencies explicitly.
---
 examples/virtio/meta.py | 10 +++++++++-
 requirements.txt        |  1 +
 2 files changed, 10 insertions(+), 1 deletion(-)
 create mode 100644 requirements.txt

diff --git a/examples/virtio/meta.py b/examples/virtio/meta.py
index e4921aa..fae2d4a 100644
--- a/examples/virtio/meta.py
+++ b/examples/virtio/meta.py
@@ -7,9 +7,17 @@ from dataclasses import dataclass
 from board import BOARDS
 from sdfgen import SystemDescription, Sddf, DeviceTree, Vmm
 from importlib.metadata import version
 from typing import Optional
 
-assert version('sdfgen').split(".")[1] == "28", "Unexpected sdfgen version"
+_sdfgen_version = version('sdfgen')
+_sdfgen_parts = _sdfgen_version.split(".")
+if len(_sdfgen_parts) < 2 or _sdfgen_parts[1] != "28":
+    raise AssertionError(
+        f"Unexpected sdfgen version {_sdfgen_version}; expected 0.28.*. "
+        "Install python deps with: pip install -r requirements.txt"
+    )
 
 ProtectionDomain = SystemDescription.ProtectionDomain
 VirtualMachine = SystemDescription.VirtualMachine
 MemoryRegion = SystemDescription.MemoryRegion
 Map = SystemDescription.Map
 Channel = SystemDescription.Channel
diff --git a/requirements.txt b/requirements.txt
new file mode 100644
index 0000000..1d3bc1c
--- /dev/null
+++ b/requirements.txt
@@ -0,0 +1 @@
+sdfgen==0.28.*
