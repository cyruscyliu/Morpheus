diff --git a/include/linux/dma_telemetry_aperture.h b/include/linux/dma_telemetry_aperture.h
index e69de29..69beeff 100644
--- a/include/linux/dma_telemetry_aperture.h
+++ b/include/linux/dma_telemetry_aperture.h
@@ -0,0 +1,105 @@
+#ifndef _LINUX_DMA_TELEMETRY_APERTURE_H
+#define _LINUX_DMA_TELEMETRY_APERTURE_H
+
+#include <linux/dma-direction.h>
+#include <linux/types.h>
+
+/*
+ * Telemetry aperture for HyperArm virtio debug instrumentation.
+ *
+ * This aperture lives inside an otherwise unused virtio transport hole and
+ * exposes a single latched event plus one 64-bit auxiliary payload. For DMA
+ * operations, the payload is normally a DMA address. For virtqueue polling
+ * and completion events, the payload can carry queue-local state such as the
+ * caller's last_used snapshot or the post-consume used index.
+ *
+ * Writers should publish fields in this order:
+ *
+ *   1. HP_DMA_ADDR_LO
+ *   2. HP_DMA_ADDR_HI
+ *   3. HP_DMA_EVENT
+ *
+ * HP_DMA_EVENT is written last and acts as the commit point for observers.
+ */
+
+#define HP_DMA_APERTURE_OFFSET              0x0c0u
+#define HP_DMA_APERTURE_SIZE                0x00cu
+
+#define HP_DMA_EVENT_OFFSET                 0x0c0u
+#define HP_DMA_ADDR_LO_OFFSET               0x0c4u
+#define HP_DMA_ADDR_HI_OFFSET               0x0c8u
+
+#define HP_DMA_EVENT(base)                  ((unsigned long)(base) + \
+					    HP_DMA_EVENT_OFFSET)
+#define HP_DMA_ADDR_LO(base)                ((unsigned long)(base) + \
+					    HP_DMA_ADDR_LO_OFFSET)
+#define HP_DMA_ADDR_HI(base)                ((unsigned long)(base) + \
+					    HP_DMA_ADDR_HI_OFFSET)
+
+/*
+ * HP_DMA_EVENT register layout
+ *
+ *  31                        18 17         10 9        8 7         0
+ * +----------------------------+-------------+----------+-----------+
+ * |          sequence          |    size     |   dir    |  opcode   |
+ * +----------------------------+-------------+----------+-----------+
+ */
+#define HP_DMA_EVENT_OPCODE_SHIFT           0u
+#define HP_DMA_EVENT_OPCODE_MASK            0x000000ffu
+#define HP_DMA_EVENT_DIRECTION_SHIFT        8u
+#define HP_DMA_EVENT_DIRECTION_MASK         0x00000300u
+#define HP_DMA_EVENT_SIZE_SHIFT             10u
+#define HP_DMA_EVENT_SIZE_MASK              0x0003fc00u
+#define HP_DMA_EVENT_SEQUENCE_SHIFT         18u
+#define HP_DMA_EVENT_SEQUENCE_MASK          0xfffc0000u
+
+#define HP_DMA_EVENT_ENCODE(opcode, direction, size, sequence) \
+	((((u32)(opcode)) << HP_DMA_EVENT_OPCODE_SHIFT) | \
+	 (((u32)(direction)) << HP_DMA_EVENT_DIRECTION_SHIFT) | \
+	 ((((u32)(size)) & 0xffu) << HP_DMA_EVENT_SIZE_SHIFT) | \
+	 (((u32)(sequence)) << HP_DMA_EVENT_SEQUENCE_SHIFT))
+
+/* HP_DMA_EVENT opcode values */
+#define HP_DMA_EVENT_OP_ALLOC_SUCCESS       0x01u
+#define HP_DMA_EVENT_OP_ALLOC_FAIL          0x02u
+#define HP_DMA_EVENT_OP_FREE                0x03u
+#define HP_DMA_EVENT_OP_MAP                 0x04u
+#define HP_DMA_EVENT_OP_MAP_FAIL            0x05u
+#define HP_DMA_EVENT_OP_UNMAP               0x06u
+#define HP_DMA_EVENT_OP_VQ_POLL_HIT         0x07u
+#define HP_DMA_EVENT_OP_VQ_POLL_MISS        0x08u
+#define HP_DMA_EVENT_OP_VQ_GET_BUF          0x09u
+#define HP_DMA_EVENT_OP_VQ_GET_BUF_EMPTY    0x0au
+
+/* HP_DMA_EVENT direction values */
+#define HP_DMA_EVENT_DIR_NONE               0x0u
+#define HP_DMA_EVENT_DIR_TO_DEVICE          0x1u
+#define HP_DMA_EVENT_DIR_FROM_DEVICE        0x2u
+#define HP_DMA_EVENT_DIR_BIDIRECTIONAL      0x3u
+
+static inline u32 hp_dma_addr_lo(u64 addr)
+{
+	return (u32)(addr & 0xffffffffull);
+}
+
+static inline u32 hp_dma_addr_hi(u64 addr)
+{
+	return (u32)((addr >> 32) & 0xffffffffull);
+}
+
+static inline u32 hp_dma_event_dir(enum dma_data_direction dir)
+{
+	switch (dir) {
+	case DMA_TO_DEVICE:
+		return HP_DMA_EVENT_DIR_TO_DEVICE;
+	case DMA_FROM_DEVICE:
+		return HP_DMA_EVENT_DIR_FROM_DEVICE;
+	case DMA_BIDIRECTIONAL:
+		return HP_DMA_EVENT_DIR_BIDIRECTIONAL;
+	case DMA_NONE:
+	default:
+		return HP_DMA_EVENT_DIR_NONE;
+	}
+}
+
+#endif /* _LINUX_DMA_TELEMETRY_APERTURE_H */
