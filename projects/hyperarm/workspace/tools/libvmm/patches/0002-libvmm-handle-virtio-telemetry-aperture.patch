diff --git a/src/virtio/console.c b/src/virtio/console.c
index 6b3cc8f..9999999 100644
--- a/src/virtio/console.c
+++ b/src/virtio/console.c
@@
 static bool virtio_console_get_device_config(struct virtio_device *dev, uint32_t offset, uint32_t *config)
 {
-    LOG_CONSOLE("operation: get device config\n");
-    return false;
+    struct virtio_console_device *console = device_state(dev);
+
+    LOG_CONSOLE("operation: get device config\n");
+    switch (offset) {
+    case 0xc0:
+        *config = console->hp_dma_event;
+        return true;
+    case 0xc4:
+        *config = console->hp_dma_addr_lo;
+        return true;
+    case 0xc8:
+        *config = console->hp_dma_addr_hi;
+        return true;
+    default:
+        /*
+         * Console config is otherwise unused here. Returning zero prevents
+         * telemetry reads from escalating into a guest-visible fault.
+         */
+        *config = 0;
+        return true;
+    }
 }
@@
 static bool virtio_console_set_device_config(struct virtio_device *dev, uint32_t offset, uint32_t config)
 {
-    LOG_CONSOLE("operation: set device config\n");
-    return false;
+    struct virtio_console_device *console = device_state(dev);
+
+    LOG_CONSOLE("operation: set device config\n");
+    switch (offset) {
+    case 0xc0:
+        console->hp_dma_event = config;
+        return true;
+    case 0xc4:
+        console->hp_dma_addr_lo = config;
+        return true;
+    case 0xc8:
+        console->hp_dma_addr_hi = config;
+        return true;
+    default:
+        /*
+         * These telemetry writes are intentionally consumed locally. The trap
+         * itself is what QEMU traces; no host-device side effect is required.
+         */
+        return true;
+    }
 }
