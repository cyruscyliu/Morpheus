{
  "name": "@morpheus/runs-viewer",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "build": "sh -c 'rm -rf .next && next build && mkdir -p .next/standalone/apps/runs-viewer/.next && rm -rf .next/standalone/apps/runs-viewer/.next/static && cp -R .next/static .next/standalone/apps/runs-viewer/.next/static'",
    "dev": "sh -c 'rm -rf .next && WATCHPACK_POLLING=\"${WATCHPACK_POLLING:-true}\" CHOKIDAR_USEPOLLING=\"${CHOKIDAR_USEPOLLING:-1}\" next dev --hostname \"${HOSTNAME:-127.0.0.1}\" --port \"${PORT:-4174}\"'",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec node --import tsx --test tests/*.ts"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elkjs": "^0.11.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3"
  }
}
