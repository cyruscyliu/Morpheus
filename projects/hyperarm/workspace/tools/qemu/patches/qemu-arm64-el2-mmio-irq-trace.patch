+static int gicv3_inject_virq_lr_index(GICv3CPUState *cs)
+{
+    int i;
+
+    if (cs->inject_lr >= 0 && cs->inject_lr < cs->num_list_regs) {
+        uint64_t lr = cs->ich_lr_el2[cs->inject_lr];
+
+        if ((lr & ICH_LR_EL2_STATE_MASK) == 0 &&
+            ((lr & ICH_LR_EL2_HW) != 0 || (lr & ICH_LR_EL2_EOI) == 0)) {
+            return cs->inject_lr;
+        }
+        return -1;
+    }
+
+    for (i = 0; i < cs->num_list_regs; i++) {
+        uint64_t lr = cs->ich_lr_el2[i];
+
+        if ((lr & ICH_LR_EL2_STATE_MASK) == 0 &&
+            ((lr & ICH_LR_EL2_HW) != 0 || (lr & ICH_LR_EL2_EOI) == 0)) {
+            return i;
+        }
+    }
+
+    return -1;
+}
+
+static bool gicv3_inject_virq_lr(GICv3CPUState *cs, int lr_idx,
+                                 uint32_t vintid, uint8_t prio,
+                                 bool group1ns)
+{
+    uint64_t lr = 0;
+
+    if (lr_idx < 0 || lr_idx >= cs->num_list_regs) {
+        return false;
+    }
+
+    cs->ich_hcr_el2 |= ICH_HCR_EL2_EN;
+
+    lr = deposit64(lr, ICH_LR_EL2_VINTID_SHIFT, ICH_LR_EL2_VINTID_LENGTH, vintid);
+    lr = deposit64(lr, ICH_LR_EL2_PRIORITY_SHIFT, ICH_LR_EL2_PRIORITY_LENGTH, prio);
+    if (group1ns) {
+        lr |= ICH_LR_EL2_GROUP;
+    }
+    lr = deposit64(lr, ICH_LR_EL2_STATE_SHIFT, ICH_LR_EL2_STATE_LENGTH,
+                   ICH_LR_EL2_STATE_PENDING);
+
+    cs->ich_lr_el2[lr_idx] = lr;
+    gicv3_cpuif_virt_update(cs);
+    trace_gicv3_inject_virq(gicv3_redist_affid(cs), vintid, lr_idx, prio,
+                            group1ns);
+    return true;
+}
+
+static void gicv3_inject_virq_timer_cb(void *opaque)
+{
+    GICv3CPUState *cs = opaque;
+    int lr_idx = -1;
+    uint64_t existing_lr = 0;
+
+    if (!cs->inject_timer || !cs->inject_vintid || !cs->inject_period_ms) {
+        return;
+    }
+
+    if (cs->num_list_regs == 0) {
+        trace_gicv3_inject_virq_skipped(gicv3_redist_affid(cs), cs->inject_vintid,
+                                        -1, 0);
+        timer_mod(cs->inject_timer,
+                  qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL) + cs->inject_period_ms);
+        return;
+    }
+
+    lr_idx = gicv3_inject_virq_lr_index(cs);
+    if (lr_idx < 0) {
+        if (cs->inject_lr >= 0 && cs->inject_lr < cs->num_list_regs) {
+            existing_lr = cs->ich_lr_el2[cs->inject_lr];
+        }
+        trace_gicv3_inject_virq_skipped(gicv3_redist_affid(cs), cs->inject_vintid,
+                                        cs->inject_lr, existing_lr);
+    } else {
+        gicv3_inject_virq_lr(cs, lr_idx, cs->inject_vintid,
+                             MORPHEUS_QEMU_INJECT_VIRQ_DEFAULT_PRIO,
+                             cs->inject_group1ns);
+    }
+
+    timer_mod(cs->inject_timer,
+              qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL) + cs->inject_period_ms);
+}
