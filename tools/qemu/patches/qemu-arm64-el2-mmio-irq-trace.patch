+static uint32_t morpheus_qemu_inject_vintid(void)
+{
+    const char *value = g_getenv(MORPHEUS_QEMU_INJECT_VIRQ_ENV);
+    char *end = NULL;
+    unsigned long long vintid;
+
+    if (!value || !*value) {
+        return 0;
+    }
+
+    vintid = g_ascii_strtoull(value, &end, 0);
+    if (end == value || *end != '\0' || vintid > GICV3_MAXIRQ) {
+        return 0;
+    }
+
+    return vintid;
+}
+
+static uint32_t morpheus_qemu_inject_period_ms(void)
+{
+    const char *value = g_getenv(MORPHEUS_QEMU_INJECT_VIRQ_PERIOD_MS_ENV);
+    char *end = NULL;
+    unsigned long long period_ms;
+
+    if (!value || !*value) {
+        return MORPHEUS_QEMU_INJECT_VIRQ_DEFAULT_PERIOD_MS;
+    }
+
+    period_ms = g_ascii_strtoull(value, &end, 0);
+    if (end == value || *end != '\0' || period_ms == 0 || period_ms > INT32_MAX) {
+        return MORPHEUS_QEMU_INJECT_VIRQ_DEFAULT_PERIOD_MS;
+    }
+
+    return period_ms;
+}
