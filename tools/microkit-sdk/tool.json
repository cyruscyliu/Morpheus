{
  "name": "microkit-sdk",
  "runtime": null,
  "cli-contract": "fetch,patch,build,inspect,logs",
  "config": {
    "fields": {
      "mode": { "aliases": ["mode"] },
      "path": { "aliases": ["path", "source"], "path": true },
      "seed-dir": { "aliases": ["seed-dir", "seedDir"], "path": true },
      "build-version": { "aliases": ["build-version", "buildVersion", "microkit-version", "microkitVersion"] },
      "archive-url": { "aliases": ["archive-url", "archiveUrl"] },
      "microkit-archive-url": { "aliases": ["microkit-archive-url", "microkitArchiveUrl"] },
      "microkit-dir": { "aliases": ["microkit-dir", "microkitDir"], "path": true },
      "downloads-dir": { "aliases": ["downloads-dir", "downloadsDir"], "path": true },
      "patch-dir": { "aliases": ["patch-dir", "patchDir"], "path": true },
      "sel4": { "aliases": ["sel4", "sel4-dir", "sel4Dir"], "path": true },
      "boards": { "aliases": ["boards"] },
      "configs": { "aliases": ["configs"] },
      "tool-target-triple": { "aliases": ["tool-target-triple", "toolTargetTriple"] },
      "toolchain-dir": { "aliases": ["toolchain-dir", "toolchainDir"], "path": true },
      "toolchain-version": { "aliases": ["toolchain-version", "toolchainVersion"] },
      "toolchain-archive-url": { "aliases": ["toolchain-archive-url", "toolchainArchiveUrl"] },
      "toolchain-prefix-aarch64": { "aliases": ["toolchain-prefix-aarch64", "toolchainPrefixAarch64"] },
      "rust-version": { "aliases": ["rust-version", "rustVersion"] },
      "reuse-build-dir": { "aliases": ["reuse-build-dir", "reuseBuildDir"], "boolean": true },
      "build-dir-key": { "aliases": ["build-dir-key", "buildDirKey"] },
      "artifacts": { "aliases": ["artifacts"], "repeatable": true }
    }
  },
  "inputs": {
    "build": {
      "dependencies": {
        "sel4": { "flag": "sel4" }
      }
    }
  },
  "managed": {
    "schemaVersion": 1,
    "modes": ["local"],
    "local": {
      "sourceTemplate": "tools/microkit-sdk/builds/{buildDirKey}/source",
      "downloadsDir": "tools/microkit-sdk/downloads",
      "artifacts": {
        "sdk-dir": {
          "pathTemplate": "tools/microkit-sdk/builds/{buildDirKey}/install"
        },
        "source-dir": {
          "pathTemplate": "tools/microkit-sdk/builds/{buildDirKey}/source"
        },
        "toolchain-dir": {
          "pathTemplate": "tools/microkit-sdk/deps/arm-gnu-toolchain-{toolchainVersion}"
        }
      },
      "commands": {
        "fetch": {
          "requiredFlags": ["path"],
          "scalarFlags": ["archive-url", "microkit-archive-url", "seed-dir", "build-version"],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/fetch.sh",
            "shell": "bash"
          },
          "fetch": {
            "archive": {
              "flag": "microkit-archive-url",
              "urlTemplate": "https://github.com/seL4/microkit/archive/{buildVersion}.tar.gz"
            }
          },
          "pathFlags": {
            "path": "tools/microkit-sdk/builds/{buildDirKey}/source",
            "source": "tools/microkit-sdk/builds/{buildDirKey}/source",
            "downloads-dir": "tools/microkit-sdk/downloads"
          },
          "result": {
            "successSummary": "fetched managed Microkit SDK source tree",
            "reusedSummary": "reused managed Microkit SDK source tree",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{path}"
            },
            "details": {
              "source": "{path}",
              "downloads_dir": "{downloads-dir}",
              "archive_url": { "fromFlag": "archive-url" },
              "build_version": { "fromFlag": "build-version" }
            }
          }
        },
        "patch": {
          "requiredFlags": ["path", "patch-dir"],
          "scalarFlags": ["patch-dir"],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/patch.sh",
            "shell": "bash"
          },
          "pathFlags": {
            "path": "tools/microkit-sdk/builds/{buildDirKey}/source",
            "source": "tools/microkit-sdk/builds/{buildDirKey}/source"
          },
          "result": {
            "successSummary": "patched managed Microkit SDK source tree",
            "reusedSummary": "reused patched managed Microkit SDK source tree",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{path}"
            },
            "details": {
              "source": "{path}",
              "patch_dir": "{patch-dir}",
              "log_file": "{path}/.morpheus-patches.log"
            }
          }
        },
        "build": {
          "pathFlags": {
            "path": "tools/microkit-sdk/builds/{buildDirKey}/source",
            "source": "tools/microkit-sdk/builds/{buildDirKey}/source",
            "downloads-dir": "tools/microkit-sdk/downloads",
            "sel4": true,
            "toolchain-dir": "tools/microkit-sdk/deps/arm-gnu-toolchain-{toolchainVersion}"
          },
          "requiredFlags": ["path", "sel4", "toolchain-dir"],
          "scalarFlags": ["boards", "configs", "tool-target-triple", "toolchain-dir", "toolchain-version", "toolchain-archive-url", "toolchain-prefix-aarch64", "archive-url", "microkit-archive-url", "seed-dir", "build-version"],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/build.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "built managed Microkit SDK install tree",
            "details": {
              "source": "{path}",
              "sel4": "{sel4}",
              "toolchain_dir": "{toolchain-dir}",
              "build_version": { "fromFlag": "build-version" }
            }
          }
        },
        "inspect": {
          "requiredFlags": ["path"],
          "scalarFlags": ["path"],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/inspect.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "inspected managed Microkit SDK source tree",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{path}"
            }
          }
        },
        "logs": {
          "requiredFlags": ["path"],
          "scalarFlags": ["path"],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/logs.sh",
            "shell": "bash"
          }
        }
      }
    }
  }
}
