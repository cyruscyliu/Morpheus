SRC_DIR = REPO_ROOT / "src"
MUTATORS_DIR = REPO_ROOT / "mutators"
if str(SRC_DIR) not in sys.path:
    sys.path.insert(0, str(SRC_DIR))
if str(MUTATORS_DIR) not in sys.path:
    sys.path.insert(0, str(MUTATORS_DIR))

