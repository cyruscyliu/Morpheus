{
  "name": "driver-callgraph",
  "runtime": null,
  "cli-contract": "build,inspect,logs",
  "config": {
    "fields": {
      "build-dir-key": {
        "aliases": [
          "build-dir-key",
          "buildDirKey"
        ]
      },
      "output": {
        "aliases": [
          "output"
        ],
        "path": true
      },
      "llcg-dot": {
        "aliases": [
          "llcg-dot",
          "llcgDot"
        ],
        "path": true
      },
      "groups-file": {
        "aliases": [
          "groups-file",
          "groupsFile"
        ],
        "path": true
      },
      "prefix-file": {
        "aliases": [
          "prefix-file",
          "prefixFile"
        ],
        "path": true
      },
      "title": {
        "aliases": [
          "title"
        ]
      }
    }
  },
  "managed": {
    "schemaVersion": 1,
    "modes": [
      "local"
    ],
    "local": {
      "sourceTemplate": "tools/driver-callgraph/src",
      "outputDirTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output",
      "artifacts": {
        "output-dir": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output"
        },
        "manifest": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-manifest.json"
        },
        "graph-display-dot": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-display.dot"
        },
        "graph-llcg-input-dot": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-llcg-input.dot"
        },
        "graph-slice-dot": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-slice.dot"
        },
        "graph-collapsed-dot": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-collapsed.dot"
        },
        "debug-json": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-debug.json"
        },
        "roots-json": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-roots.json"
        },
        "groups-json": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-groups.json"
        },
        "graph-raw-dot": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-raw.dot"
        },
        "graph-display-svg": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-display.svg"
        },
        "graph-raw-svg": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-raw.svg"
        },
        "graph-display-pdf": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-display.pdf"
        },
        "graph-raw-pdf": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/driver-callgraph-raw.pdf"
        },
        "build-log": {
          "pathTemplate": "tools/driver-callgraph/builds/{buildDirKey}/output/build.log"
        }
      },
      "commands": {
        "build": {
          "requiredFlags": [
            "llcg-dot",
            "output"
          ],
          "scalarFlags": [
            "build-dir-key",
            "llcg-dot",
            "groups-file",
            "prefix-file",
            "output",
            "title"
          ],
          "repeatableFlags": [],
          "pathFlags": {
            "output": "tools/driver-callgraph/builds/{buildDirKey}/output"
          },
          "script": {
            "path": "scripts/build.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "built driver lifecycle base graph",
            "errorSummary": "driver lifecycle base graph build failed",
            "artifact": {
              "path": "output-dir",
              "locationTemplate": "{output}"
            },
            "details": {
              "output": "{output}",
              "llcg_dot": {
                "fromFlag": "llcg-dot"
              },
              "groups_file": {
                "fromFlag": "groups-file"
              },
              "prefix_file": {
                "fromFlag": "prefix-file"
              }
            }
          }
        },
        "inspect": {
          "requiredFlags": [
            "output"
          ],
          "scalarFlags": [
            "output"
          ],
          "repeatableFlags": [],
          "pathFlags": {
            "output": "tools/driver-callgraph/builds/{buildDirKey}/output"
          },
          "script": {
            "path": "scripts/inspect.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "inspected driver lifecycle base graph",
            "artifact": {
              "path": "manifest",
              "locationTemplate": "{output}/driver-callgraph-manifest.json"
            }
          }
        },
        "logs": {
          "requiredFlags": [
            "output"
          ],
          "scalarFlags": [
            "output"
          ],
          "repeatableFlags": [],
          "pathFlags": {
            "output": "tools/driver-callgraph/builds/{buildDirKey}/output"
          },
          "script": {
            "path": "scripts/logs.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "reported driver lifecycle base graph logs",
            "artifact": {
              "path": "build-log",
              "locationTemplate": "{output}/build.log"
            }
          }
        }
      }
    }
  }
}
