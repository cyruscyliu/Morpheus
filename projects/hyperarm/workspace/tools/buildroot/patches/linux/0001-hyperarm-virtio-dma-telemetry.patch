+/*
+ * Log DMA visibility and a small set of virtqueue progress events from
+ * virtio_ring.c, where both the sharing decisions and used-ring harvesting
+ * are centralized.
+ */
+static atomic_t hp_dma_trace_seq = ATOMIC_INIT(0);
+
+static bool hp_dma_trace_via_mmio(struct virtio_device *vdev)
+{
+	const char *bus_name;
+
+	if (!vdev->config || !vdev->config->set || !vdev->config->bus_name)
+		return false;
+
+	bus_name = vdev->config->bus_name(vdev);
+
+	return bus_name && !strcmp(bus_name, "virtio-mmio");
+}
+
+static void hp_dma_trace_publish(struct virtio_device *vdev, u32 opcode,
+				 enum dma_data_direction dir, size_t size,
+				 dma_addr_t addr)
+{
+	__le32 event;
+	__le32 addr_lo;
+	__le32 addr_hi;
+	u32 sequence;
+
+	if (!hp_dma_trace_via_mmio(vdev))
+		return;
+
+	/*
+	 * Publish the payload first and commit with HP_DMA_EVENT last so EL2
+	 * observers never decode a partially updated record.
+	 */
+	sequence = (u32)atomic_inc_return(&hp_dma_trace_seq) &
+		   (HP_DMA_EVENT_SEQUENCE_MASK >>
+		    HP_DMA_EVENT_SEQUENCE_SHIFT);
+	addr_lo = cpu_to_le32(hp_dma_addr_lo((u64)addr));
+	addr_hi = cpu_to_le32(hp_dma_addr_hi((u64)addr));
+	event = cpu_to_le32(HP_DMA_EVENT_ENCODE(opcode,
+						hp_dma_event_dir(dir),
+						size,
+						sequence));
+
+	vdev->config->set(vdev, HP_DMA_ADDR_LO_OFFSET, &addr_lo,
+			  sizeof(addr_lo));
+	vdev->config->set(vdev, HP_DMA_ADDR_HI_OFFSET, &addr_hi,
+			  sizeof(addr_hi));
+	vdev->config->set(vdev, HP_DMA_EVENT_OFFSET, &event,
+			  sizeof(event));
+}
+
+#define HP_DMA_OP_NAME(_op)						\
+	((_op) == HP_DMA_EVENT_OP_ALLOC_SUCCESS ? "alloc" :		\
+	 (_op) == HP_DMA_EVENT_OP_ALLOC_FAIL ? "alloc_fail" :		\
+	 (_op) == HP_DMA_EVENT_OP_FREE ? "free" :			\
+	 (_op) == HP_DMA_EVENT_OP_MAP ? "map" :				\
+	 (_op) == HP_DMA_EVENT_OP_MAP_FAIL ? "map_fail" :		\
+	 (_op) == HP_DMA_EVENT_OP_UNMAP ? "unmap" :			\
+	 (_op) == HP_DMA_EVENT_OP_VQ_POLL_HIT ? "vq_poll_hit" :	\
+	 (_op) == HP_DMA_EVENT_OP_VQ_POLL_MISS ? "vq_poll_miss" :	\
+	 (_op) == HP_DMA_EVENT_OP_VQ_GET_BUF ? "vq_get_buf" :		\
+	 (_op) == HP_DMA_EVENT_OP_VQ_GET_BUF_EMPTY ?			\
+	 "vq_get_buf_empty" : "unknown")
+
+#define HP_DMA_DIR_NAME(_dir)						\
+	((_dir) == HP_DMA_EVENT_DIR_BIDIRECTIONAL ? "bidirectional" :	\
+	 (_dir) == HP_DMA_EVENT_DIR_TO_DEVICE ? "to_device" :		\
+	 (_dir) == HP_DMA_EVENT_DIR_FROM_DEVICE ? "from_device" :	\
+	 (_dir) == HP_DMA_EVENT_DIR_NONE ? "none" : "unknown")
+
+#define HP_DMA_TRACE(_vdev, _op, _dir, _size, _addr, _kind, _use_dma)	\
+	do {								\
+		u32 hp_dma_trace_dir = hp_dma_event_dir(_dir);		\
+		dma_addr_t hp_dma_trace_addr = (_addr);			\
+		/* The trapped config-space write is the telemetry signal.
+		 * EL2 can observe it even if later software ignores the
+		 * payload contents.
+		 */							\
+		hp_dma_trace_publish((_vdev), (_op), (_dir), (_size),	\
+				     hp_dma_trace_addr);			\
+									\
+		dev_info_ratelimited(&(_vdev)->dev,			\
+				     "virtio_telemetry op=%s kind=%s "	\
+				     "dir=%s size=%zu aux=%pad "	\
+				     "path=%s\n",			\
+				     HP_DMA_OP_NAME(_op), (_kind),	\
+				     HP_DMA_DIR_NAME(hp_dma_trace_dir),	\
+				     (size_t)(_size),			\
+				     &hp_dma_trace_addr,		\
+				     (_use_dma) ? "dma_api" : "phys");	\
+	} while (0)
+
