diff --git a/lib/Kconfig.kasan b/lib/Kconfig.kasan
--- a/lib/Kconfig.kasan
+++ b/lib/Kconfig.kasan
@@ -62,6 +62,15 @@ if KASAN
 
 if KASAN
 
+config HYPERARM_KASAN_DRIVERS_ONLY
+	bool "Limit KASAN compiler instrumentation to drivers/"
+	default n
+	help
+	  Limit compiler-inserted KASAN checks to objects built under
+	  drivers/. The KASAN runtime remains enabled, but non-driver kernel
+	  objects are built with the normal KASAN no-sanitize flags to reduce
+	  unrelated boot-time noise in HyperArm nested fuzzing runs.
+
 config CC_HAS_KASAN_MEMINTRINSIC_PREFIX
 	def_bool (CC_IS_CLANG && $(cc-option,-fsanitize=kernel-address -mllvm -asan-kernel-mem-intrinsic-prefix=1)) || \
 		 (CC_IS_GCC && $(cc-option,-fsanitize=kernel-address --param asan-kernel-mem-intrinsic-prefix=1))
diff --git a/scripts/Makefile.lib b/scripts/Makefile.lib
--- a/scripts/Makefile.lib
+++ b/scripts/Makefile.lib
@@ -56,9 +56,17 @@ ifeq ($(CONFIG_KASAN),y)
 ifneq ($(CONFIG_KASAN_HW_TAGS),y)
+ifeq ($(CONFIG_HYPERARM_KASAN_DRIVERS_ONLY),y)
+ifneq ($(filter drivers/%,$(obj) $(src)),)
+__kasan_scope := $(KASAN_SANITIZE_$(target-stem).o)$(KASAN_SANITIZE)$(is-kernel-object)
+endif
+else
+__kasan_scope := $(KASAN_SANITIZE_$(target-stem).o)$(KASAN_SANITIZE)$(is-kernel-object)
+endif
+
 _c_flags += $(if $(patsubst n%,, \
-		$(KASAN_SANITIZE_$(target-stem).o)$(KASAN_SANITIZE)$(is-kernel-object)), \
+		$(__kasan_scope)), \
 		$(CFLAGS_KASAN), $(CFLAGS_KASAN_NOSANITIZE))
 _rust_flags += $(if $(patsubst n%,, \
-		$(KASAN_SANITIZE_$(target-stem).o)$(KASAN_SANITIZE)$(is-kernel-object)), \
+		$(__kasan_scope)), \
 		$(RUSTFLAGS_KASAN))
endif
endif
diff --git a/drivers/virtio/Makefile b/drivers/virtio/Makefile
--- a/drivers/virtio/Makefile
+++ b/drivers/virtio/Makefile
@@ -4,6 +4,7 @@ obj-$(CONFIG_VIRTIO) += virtio.o virtio_ring.o
 obj-$(CONFIG_VIRTIO_ANCHOR) += virtio_anchor.o
 obj-$(CONFIG_VIRTIO_PCI_LIB) += virtio_pci_modern_dev.o
 obj-$(CONFIG_VIRTIO_PCI_LIB_LEGACY) += virtio_pci_legacy_dev.o
+KASAN_SANITIZE_virtio_mmio.o := y
 obj-$(CONFIG_VIRTIO_MMIO) += virtio_mmio.o
 obj-$(CONFIG_VIRTIO_PCI) += virtio_pci.o
 virtio_pci-y := virtio_pci_modern.o virtio_pci_common.o
