{
  "name": "libafl",
  "runtime": null,
  "cli-contract": "fetch,patch,build,exec,inspect",
  "config": {
    "fields": {
      "mode": {
        "aliases": [
          "mode"
        ]
      },
      "source": {
        "aliases": [
          "source"
        ],
        "path": true
      },
      "seed-dir": {
        "aliases": [
          "seed-dir",
          "seedDir"
        ],
        "path": true
      },
      "build-version": {
        "aliases": [
          "build-version",
          "buildVersion",
          "git-ref",
          "gitRef"
        ]
      },
      "git-url": {
        "aliases": [
          "git-url",
          "gitUrl"
        ]
      },
      "patch-dir": {
        "aliases": [
          "patch-dir",
          "patchDir"
        ],
        "path": true
      },
      "patch-script": {
        "aliases": [
          "patch-script",
          "patchScript"
        ],
        "path": true
      },
      "reuse-build-dir": {
        "aliases": [
          "reuse-build-dir",
          "reuseBuildDir"
        ],
        "boolean": true
      },
      "build-dir-key": {
        "aliases": [
          "build-dir-key",
          "buildDirKey"
        ]
      },
      "build-script": {
        "aliases": [
          "build-script",
          "buildScript"
        ],
        "path": true
      },
      "cargo-arg": {
        "aliases": [
          "cargo-arg",
          "cargo-args",
          "cargoArgs"
        ],
        "repeatable": true
      },
      "inspect-script": {
        "aliases": [
          "inspect-script",
          "inspectScript"
        ],
        "path": true
      },
      "run-dir": {
        "aliases": [
          "run-dir",
          "runDir"
        ],
        "path": true
      },
      "harness-script": {
        "aliases": [
          "harness-script",
          "harnessScript"
        ],
        "path": true
      },
      "harness-arg": {
        "aliases": [
          "harness-arg",
          "harness-args",
          "harnessArgs"
        ],
        "repeatable": true
      },
      "detach": {
        "aliases": [
          "detach"
        ],
        "boolean": true
      },
      "run-seconds": {
        "aliases": [
          "run-seconds",
          "runSeconds"
        ]
      },
      "artifacts": {
        "aliases": [
          "artifacts"
        ],
        "repeatable": true
      }
    }
  },
  "managed": {
    "schemaVersion": 1,
    "modes": [
      "local"
    ],
    "local": {
      "sourceTemplate": "tools/libafl/builds/{buildDirKey}/source",
      "buildDirTemplate": "tools/libafl/builds/{buildDirKey}/build",
      "installDirTemplate": "tools/libafl/builds/{buildDirKey}/install",
      "execDirTemplate": "tools/libafl/runs/{buildDirKey}",
      "artifacts": {
        "source-dir": {
          "pathTemplate": "tools/libafl/builds/{buildDirKey}/source"
        },
        "run-manifest": {
          "pathTemplate": "tools/libafl/runs/{buildDirKey}/manifest.json"
        }
      },
      "commands": {
        "fetch": {
          "requiredFlags": [
            "source"
          ],
          "scalarFlags": [
            "git-url",
            "seed-dir",
            "build-version"
          ],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/fetch.sh",
            "shell": "bash"
          },
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source"
          },
          "result": {
            "successSummary": "fetched managed LibAFL source tree",
            "reusedSummary": "reused managed LibAFL source tree",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{source}"
            },
            "details": {
              "source": "{source}",
              "build_version": {
                "fromFlag": "build-version"
              },
              "git_url": {
                "fromFlag": "git-url"
              }
            }
          }
        },
        "patch": {
          "requiredFlags": [
            "source",
            "patch-dir"
          ],
          "scalarFlags": [
            "patch-dir",
            "patch-script"
          ],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/patch.sh",
            "shell": "bash"
          },
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source"
          },
          "result": {
            "successSummary": "patched managed LibAFL source tree",
            "reusedSummary": "reused patched managed LibAFL source tree",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{source}"
            },
            "details": {
              "source": "{source}",
              "patch_dir": "{patch-dir}"
            }
          }
        },
        "build": {
          "requiredFlags": [
            "source",
            "build-dir",
            "install-dir"
          ],
          "scalarFlags": [
            "source",
            "build-dir",
            "install-dir",
            "patch-dir",
            "build-script",
            "reuse-build-dir",
            "build-version",
            "git-url",
            "seed-dir"
          ],
          "repeatableFlags": [
            "cargo-arg"
          ],
          "script": {
            "path": "scripts/build.sh",
            "shell": "bash",
            "cwdTemplate": "{build-dir}"
          },
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source",
            "build-dir": "tools/libafl/builds/{buildDirKey}/build",
            "install-dir": "tools/libafl/builds/{buildDirKey}/install"
          },
          "result": {
            "successSummary": "built local libafl harness artifacts",
            "reusedSummary": "reused local libafl harness build",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{source}"
            },
            "details": {
              "source": "{source}",
              "build_dir": "{build-dir}",
              "install_dir": "{install-dir}"
            }
          }
        },
        "inspect": {
          "requiredFlags": [
            "source"
          ],
          "scalarFlags": [
            "source",
            "build-dir",
            "install-dir",
            "inspect-script",
            "build-version",
            "git-url"
          ],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/inspect.sh",
            "shell": "bash"
          },
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source",
            "build-dir": "tools/libafl/builds/{buildDirKey}/build",
            "install-dir": "tools/libafl/builds/{buildDirKey}/install"
          },
          "result": {
            "successSummary": "inspected managed LibAFL build",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{source}"
            }
          }
        },
        "exec": {
          "requiredFlags": [
            "source",
            "run-dir",
            "install-dir",
            "harness-script"
          ],
          "scalarFlags": [
            "source",
            "run-dir",
            "install-dir",
            "harness-script",
            "detach",
            "run-seconds",
            "build-version",
            "build-dir-key"
          ],
          "repeatableFlags": [
            "harness-arg"
          ],
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source",
            "install-dir": "tools/libafl/builds/{buildDirKey}/install",
            "run-dir": "tools/libafl/runs/{buildDirKey}"
          },
          "script": {
            "path": "scripts/exec.sh",
            "shell": "bash",
            "cwdTemplate": "{run-dir}"
          },
          "result": {
            "successSummary": "launched host-side libafl harness",
            "attachedSuccessSummary": "completed host-side libafl harness",
            "errorSummary": "host-side libafl harness launch failed",
            "artifact": {
              "path": "run-manifest",
              "locationTemplate": "{run-dir}/manifest.json"
            },
            "details": {
              "run_dir": "{run-dir}",
              "manifest": "{run-dir}/manifest.json"
            }
          }
        }
      }
    }
  }
}
