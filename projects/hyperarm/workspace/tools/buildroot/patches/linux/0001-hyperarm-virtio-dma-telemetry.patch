+static void hyperarm_virtio_oracle_check(u32 value)
+{
+	if (!hyperarm_virtio_oracle_bug_enabled ||
+	    ((value & 0xffu) != HYPERARM_VIRTIO_ORACLE_MAGIC0 &&
+	     (value & 0xffu) != HYPERARM_VIRTIO_ORACLE_MAGIC1))
+		return;
