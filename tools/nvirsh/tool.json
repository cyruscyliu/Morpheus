{
  "name": "nvirsh",
  "runtime": null,
  "cli-contract": "exec,inspect,logs,stop",
  "runGuard": {
    "scope": "workspace",
    "keyTemplate": "{target}:{runtime.provider.action}"
  },
  "config": {
    "fields": {
      "mode": { "aliases": ["mode"] },
      "path": { "aliases": ["path"], "path": true },
      "state-dir": { "aliases": ["state-dir", "stateDir"], "path": true },
      "target": { "aliases": ["target"] },
      "name": { "aliases": ["name"] },
      "board": { "aliases": ["board"] },
      "qemu": { "aliases": ["qemu"], "path": true },
      "microkit-sdk": { "aliases": ["microkit-sdk", "microkitSdk"], "path": true },
      "microkit-version": { "aliases": ["microkit-version", "microkitVersion"] },
      "microkit-config": { "aliases": ["microkit-config", "microkitConfig"] },
      "toolchain": { "aliases": ["toolchain"], "path": true },
      "libvmm-dir": { "aliases": ["libvmm-dir", "libvmmDir"], "path": true },
      "runtime-contract": { "aliases": ["runtime-contract", "runtimeContract"], "path": true },
      "runtime-action": { "aliases": ["runtime-action", "runtimeAction"] },
      "kernel": { "aliases": ["kernel"], "path": true },
      "initrd": { "aliases": ["initrd"], "path": true },
      "qemu-arg": { "aliases": ["qemu-arg", "qemu-args", "qemuArgs"], "repeatable": true },
      "attach": { "aliases": ["attach"], "boolean": true },
      "dependencies": { "aliases": ["dependencies"] }
    }
  },
  "inputs": {
    "run": {
      "dependencies": {
        "qemu": { "flag": "qemu" },
        "microkit-sdk": { "flag": "microkit-sdk" },
        "toolchain-bin-dir": { "flag": "toolchain" },
        "libvmm-dir": { "flag": "libvmm-dir" },
        "kernel": { "flag": "kernel" },
        "initrd": { "flag": "initrd" }
      },
      "config": {
        "runtime.provider": { "flag": "runtime-contract" }
      }
    }
  },
  "managed": {
    "schemaVersion": 1,
    "modes": ["local"],
    "local": {
      "execDirTemplate": "tmp/nvirsh/exec",
      "commands": {
        "exec": {
          "requiredFlags": ["qemu", "microkit-sdk", "toolchain", "libvmm-dir", "kernel", "initrd"],
          "scalarFlags": ["state-dir", "target", "name", "board", "qemu", "microkit-sdk", "microkit-version", "microkit-config", "toolchain", "libvmm-dir", "runtime-contract", "runtime-action", "kernel", "initrd"],
          "repeatableFlags": ["qemu-arg", "env"],
          "script": {
            "path": "scripts/exec.sh",
            "shell": "bash"
          },
          "details": {
            "state_dir": "{state-dir}"
          }
        },
        "inspect": {
          "requiredFlags": [],
          "scalarFlags": ["state-dir"],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/inspect.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "inspected managed nvirsh state"
          }
        },
        "logs": {
          "requiredFlags": [],
          "scalarFlags": ["state-dir"],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/logs.sh",
            "shell": "bash"
          }
        },
        "stop": {
          "requiredFlags": [],
          "scalarFlags": ["state-dir"],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/stop.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "stopped managed nvirsh state",
            "details": {
              "state_dir": "{state-dir}"
            }
          }
        }
      }
    }
  }
}
