{
  "name": "nvirsh",
  "runtime": null,
  "cli-contract": "fetch,build,exec,inspect,stop",
  "config": {
    "fields": {
      "source": {
        "aliases": [
          "source"
        ],
        "path": true
      },
      "qemu": {
        "aliases": [
          "qemu"
        ],
        "path": true
      },
      "firmware": {
        "aliases": [
          "firmware"
        ],
        "path": true
      },
      "buildroot-output-dir": {
        "aliases": [
          "buildroot-output-dir",
          "buildrootOutputDir"
        ],
        "path": true
      },
      "build-version": {
        "aliases": [
          "build-version",
          "buildVersion",
          "profile"
        ]
      },
      "phase": {
        "aliases": [
          "phase"
        ]
      },
      "run-dir": {
        "aliases": [
          "run-dir",
          "runDir"
        ],
        "path": true
      },
      "build-dir-key": {
        "aliases": [
          "build-dir-key",
          "buildDirKey"
        ]
      }
    }
  },
  "inputs": {
    "build": {
      "dependencies": {
        "qemu": {
          "flag": "qemu"
        },
        "buildroot": {
          "flag": "buildroot-output-dir"
        }
      }
    }
  },
  "managed": {
    "schemaVersion": 1,
    "modes": [
      "local"
    ],
    "local": {
      "sourceTemplate": "tools/nvirsh/builds/{buildDirKey}/source",
      "buildDirTemplate": "tools/nvirsh/builds/{buildDirKey}/build",
      "installDirTemplate": "tools/nvirsh/builds/{buildDirKey}/install",
      "execDirTemplate": "tools/nvirsh/runs/{buildDirKey}",
      "artifacts": {
        "profile-source": {
          "pathTemplate": "tools/nvirsh/builds/{buildDirKey}/source"
        },
        "prepared-state": {
          "pathTemplate": "tools/nvirsh/builds/{buildDirKey}/install/state.json"
        },
        "run-manifest": {
          "pathTemplate": "tools/nvirsh/runs/{buildDirKey}/manifest.json"
        }
      },
      "commands": {
        "fetch": {
          "requiredFlags": [
            "source"
          ],
          "scalarFlags": [
            "source",
            "build-version",
            "build-dir-key"
          ],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/fetch.sh",
            "shell": "bash",
            "cwdTemplate": "{source}"
          },
          "result": {
            "successSummary": "prepared nvirsh profile source tree",
            "reusedSummary": "reused nvirsh profile source tree",
            "artifact": {
              "path": "profile-source",
              "locationTemplate": "{source}"
            },
            "details": {
              "source": "{source}",
              "profile": {
                "fromFlag": "build-version"
              },
              "build_dir_key": {
                "fromFlag": "build-dir-key"
              }
            }
          }
        },
        "build": {
          "requiredFlags": [
            "source",
            "build-dir",
            "install-dir",
            "qemu",
            "firmware",
            "buildroot-output-dir"
          ],
          "scalarFlags": [
            "source",
            "build-dir",
            "install-dir",
            "qemu",
            "firmware",
            "buildroot-output-dir",
            "build-version",
            "build-dir-key",
            "phase"
          ],
          "repeatableFlags": [],
          "pathFlags": {
            "source": "tools/nvirsh/builds/{buildDirKey}/source",
            "build-dir": "tools/nvirsh/builds/{buildDirKey}/build",
            "install-dir": "tools/nvirsh/builds/{buildDirKey}/install",
            "qemu": "tools/qemu/builds/{buildDirKey}/install/bin/qemu-system-aarch64",
            "buildroot-output-dir": "tools/buildroot/builds/{buildDirKey}/output"
          },
          "script": {
            "path": "scripts/build.sh",
            "shell": "bash",
            "cwdTemplate": "{build-dir}"
          },
          "result": {
            "successSummary": "prepared nvirsh nested stack state",
            "reusedSummary": "reused nvirsh nested stack state",
            "artifact": {
              "path": "prepared-state",
              "locationTemplate": "{install-dir}/state.json"
            },
            "details": {
              "source": "{source}",
              "build_dir": "{build-dir}",
              "install_dir": "{install-dir}",
              "state_file": "{install-dir}/state.json",
              "profile": {
                "fromFlag": "build-version"
              }
            }
          }
        },
        "exec": {
          "requiredFlags": [
            "source",
            "run-dir",
            "install-dir",
            "phase"
          ],
          "scalarFlags": [
            "source",
            "run-dir",
            "install-dir",
            "phase",
            "build-version",
            "build-dir-key"
          ],
          "repeatableFlags": [],
          "pathFlags": {
            "source": "tools/nvirsh/builds/{buildDirKey}/source",
            "install-dir": "tools/nvirsh/builds/{buildDirKey}/install"
          },
          "script": {
            "path": "scripts/exec.sh",
            "shell": "bash",
            "cwdTemplate": "{run-dir}"
          },
          "result": {
            "successSummary": "advanced nvirsh nested stack phase",
            "attachedSuccessSummary": "completed nvirsh nested stack phase",
            "errorSummary": "nvirsh nested stack phase failed",
            "details": {
              "run_dir": "{run-dir}",
              "log_file": "{run-dir}/stdout.log",
              "manifest": "{run-dir}/manifest.json"
            }
          }
        },
        "inspect": {
          "requiredFlags": [
            "source"
          ],
          "scalarFlags": [
            "source",
            "run-dir",
            "install-dir",
            "build-dir",
            "build-version",
            "build-dir-key"
          ],
          "repeatableFlags": [],
          "pathFlags": {
            "source": "tools/nvirsh/builds/{buildDirKey}/source",
            "install-dir": "tools/nvirsh/builds/{buildDirKey}/install",
            "build-dir": "tools/nvirsh/builds/{buildDirKey}/build"
          },
          "script": {
            "path": "scripts/inspect.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "inspected nvirsh nested stack state",
            "artifact": {
              "path": "prepared-state",
              "locationTemplate": "{install-dir}/state.json"
            }
          }
        },
        "stop": {
          "requiredFlags": [],
          "scalarFlags": [
            "source",
            "run-dir",
            "install-dir",
            "build-version",
            "build-dir-key"
          ],
          "repeatableFlags": [],
          "pathFlags": {
            "source": "tools/nvirsh/builds/{buildDirKey}/source",
            "install-dir": "tools/nvirsh/builds/{buildDirKey}/install"
          },
          "script": {
            "path": "scripts/stop.sh",
            "shell": "bash"
          },
          "result": {
            "successSummary": "stopped nvirsh nested stack"
          }
        }
      }
    }
  }
}
