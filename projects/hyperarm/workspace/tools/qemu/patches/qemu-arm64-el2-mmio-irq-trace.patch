+static uint64_t arm_el2_fault_ipa(CPUARMState *env)
+{
+    uint64_t hpfar = env->cp15.hpfar_el2 & ~HPFAR_NS;
+    uint64_t ipa = (hpfar >> 4) << 12;
+
+    return ipa | (env->exception.vaddress & 0xfff);
+}
+
+static void trace_el1_to_el2_mmio_abort(CPUARMState *env)
+{
+    uint32_t syndrome = env->exception.syndrome;
+    uint32_t ec = syn_get_ec(syndrome);
+    uint64_t ipa = arm_el2_fault_ipa(env);
+    uint64_t value = 0;
+
+    if (arm_current_el(env) != 1 || env->exception.target_el != 2) {
+        return;
+    }
+
+    if (ec != EC_DATAABORT && ec != EC_DATAABORT_SAME_EL) {
+        return;
+    }
+
+    if (syndrome & (1U << 6)) {
+        if (syndrome & ARM_EL_ISV) {
+            unsigned int srt = extract32(syndrome, 16, 5);
+
+            if (srt != 31) {
+                value = env->xregs[srt];
+            }
+        }
+        trace_arm_mmio_el2_from_el1_write(env->pc, ipa, syndrome, value);
+    } else {
+        trace_arm_mmio_el2_from_el1_read_request(env->pc, ipa, syndrome);
+    }
+}
