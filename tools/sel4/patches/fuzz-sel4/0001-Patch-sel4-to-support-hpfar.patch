From 5fbe354f51fd5114d6ae43863f7658b1dbbc9032 Mon Sep 17 00:00:00 2001
From: Qiang Liu <cyruscyliu@gmail.com>
Date: Mon, 1 Dec 2025 16:55:27 +0100
Subject: [PATCH 1/2] Patch sel4 to support hpfar

---
 configs/include/AARCH64_verified_include.cmake    | 2 +-
 include/arch/arm/arch/64/mode/fastpath/fastpath.h | 2 ++
 include/arch/arm/arch/64/mode/machine.h           | 9 +++++++++
 src/arch/arm/64/kernel/vspace.c                   | 8 +++++++-
 4 files changed, 19 insertions(+), 2 deletions(-)

diff --git a/configs/include/AARCH64_verified_include.cmake b/configs/include/AARCH64_verified_include.cmake
index e83c5fe09..82367d0e6 100644
--- a/configs/include/AARCH64_verified_include.cmake
+++ b/configs/include/AARCH64_verified_include.cmake
@@ -18,7 +18,7 @@ set(KernelRetypeFanOutLimit "256" CACHE STRING "")
 set(KernelBenchmarks "none" CACHE STRING "")
 set(KernelDangerousCodeInjection OFF CACHE BOOL "")
 set(KernelFastpath ON CACHE BOOL "")
-set(KernelPrinting OFF CACHE BOOL "")
+set(KernelPrinting ON CACHE BOOL "")
 set(KernelNumDomains 16 CACHE STRING "")
 set(KernelMaxNumBootinfoUntypedCaps 50 CACHE STRING "")
 set(KernelArmSMMU OFF CACHE BOOL "")
diff --git a/include/arch/arm/arch/64/mode/fastpath/fastpath.h b/include/arch/arm/arch/64/mode/fastpath/fastpath.h
index 12d55f3c9..b75d23761 100644
--- a/include/arch/arm/arch/64/mode/fastpath/fastpath.h
+++ b/include/arch/arm/arch/64/mode/fastpath/fastpath.h
@@ -63,6 +63,8 @@ static inline void fastpath_set_tcbfault_vm_fault(vm_fault_type_t type)
         /* use the IPA */
         if (ARCH_NODE_STATE(armHSVCPUActive)) {
             addr = GET_PAR_ADDR(addressTranslateS1(addr)) | (addr & MASK(PAGE_BITS));
+            addr = ((getHPFAR() & 0xFFFFFFFFFF) >> 4) | (addr & MASK(PAGE_BITS));
+            fail("get hpfar 222");
         }
 #endif
         NODE_STATE(ksCurThread)->tcbFault = seL4_Fault_VMFault_new(addr, fault, false);
diff --git a/include/arch/arm/arch/64/mode/machine.h b/include/arch/arm/arch/64/mode/machine.h
index d869e3926..62474b5ca 100644
--- a/include/arch/arm/arch/64/mode/machine.h
+++ b/include/arch/arm/arch/64/mode/machine.h
@@ -347,6 +347,15 @@ static inline word_t PURE getFAR(void)
     return FAR;
 }
 
+#ifdef CONFIG_ARM_HYPERVISOR_SUPPORT
+static inline word_t PURE getHPFAR(void)
+{
+    word_t HPFAR;
+    MRS("hpfar_el2", HPFAR);
+    return HPFAR;
+}
+#endif
+
 static inline word_t ats1e2r(word_t va)
 {
     word_t par;
diff --git a/src/arch/arm/64/kernel/vspace.c b/src/arch/arm/64/kernel/vspace.c
index 728112093..2579a6928 100644
--- a/src/arch/arm/64/kernel/vspace.c
+++ b/src/arch/arm/64/kernel/vspace.c
@@ -714,15 +714,21 @@ exception_t handleVMFault(tcb_t *thread, vm_fault_type_t vm_faultType)
 {
     switch (vm_faultType) {
     case ARMDataAbort: {
-        word_t addr, fault;
+        word_t addr, addr2, fault;
 
         addr = getFAR();
         fault = getDFSR();
 
 #ifdef CONFIG_ARM_HYPERVISOR_SUPPORT
+        // userError("far=0x%lx\n", addr);
         /* use the IPA */
         if (ARCH_NODE_STATE(armHSVCPUActive)) {
             addr = GET_PAR_ADDR(addressTranslateS1(addr)) | (addr & MASK(PAGE_BITS));
+            // userError("addr=0x%lx\n", addr);
+            addr2 = getHPFAR();
+            // userError("addr2=0x%lx\n", addr2);
+            addr = (((addr2 & 0xFFFFFFFFFF) >> 4) << 12) | (addr & MASK(PAGE_BITS));
+            // userError("addr=0x%lx\n", addr);
         }
 #endif
         current_fault = seL4_Fault_VMFault_new(addr, fault, false);
-- 
2.47.3

