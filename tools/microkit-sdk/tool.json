{
  "name": "microkit-sdk",
  "runtime": "node",
  "cli-contract": "fetch,patch,build,inspect,logs",
  "entry": "dist/index.js",
  "config": {
    "fields": {
      "mode": { "aliases": ["mode"] },
      "path": { "aliases": ["path", "source"], "path": true },
      "build-version": { "aliases": ["build-version", "buildVersion", "microkit-version", "microkitVersion"] },
      "archive-url": { "aliases": ["archive-url", "archiveUrl"] },
      "microkit-archive-url": { "aliases": ["microkit-archive-url", "microkitArchiveUrl"] },
      "microkit-dir": { "aliases": ["microkit-dir", "microkitDir"], "path": true },
      "downloads-dir": { "aliases": ["downloads-dir", "downloadsDir"], "path": true },
      "patch-dir": { "aliases": ["patch-dir", "patchDir"], "path": true },
      "sel4": { "aliases": ["sel4", "sel4-dir", "sel4Dir"], "path": true },
      "boards": { "aliases": ["boards"] },
      "configs": { "aliases": ["configs"] },
      "tool-target-triple": { "aliases": ["tool-target-triple", "toolTargetTriple"] },
      "toolchain-dir": { "aliases": ["toolchain-dir", "toolchainDir"], "path": true },
      "toolchain-version": { "aliases": ["toolchain-version", "toolchainVersion"] },
      "toolchain-archive-url": { "aliases": ["toolchain-archive-url", "toolchainArchiveUrl"] },
      "toolchain-prefix-aarch64": { "aliases": ["toolchain-prefix-aarch64", "toolchainPrefixAarch64"] },
      "rust-version": { "aliases": ["rust-version", "rustVersion"] },
      "reuse-build-dir": { "aliases": ["reuse-build-dir", "reuseBuildDir"], "boolean": true },
      "build-dir-key": { "aliases": ["build-dir-key", "buildDirKey"] },
      "artifacts": { "aliases": ["artifacts"], "repeatable": true }
    }
  },
  "inputs": {
    "build": {
      "dependencies": {
        "sel4": { "flag": "sel4" }
      }
    }
  },
  "managed": {
    "schemaVersion": 1,
    "modes": ["local"],
    "local": {
      "sourceTemplate": "tools/microkit-sdk/builds/{buildDirKey}/source",
      "downloadsDir": "tools/microkit-sdk/downloads",
      "artifacts": {
        "sdk-dir": {
          "pathTemplate": "tools/microkit-sdk/builds/{buildDirKey}/install"
        },
        "source-dir": {
          "pathTemplate": "tools/microkit-sdk/builds/{buildDirKey}/source"
        },
        "toolchain-dir": {
          "pathTemplate": "tools/microkit-sdk/deps/arm-gnu-toolchain-{toolchainVersion}"
        }
      },
      "commands": {
        "fetch": {
          "pathFlags": {
            "source": "tools/microkit-sdk/builds/{buildDirKey}/source",
            "downloads-dir": "tools/microkit-sdk/downloads"
          }
        },
        "build": {
          "pathFlags": {
            "source": "tools/microkit-sdk/builds/{buildDirKey}/source",
            "downloads-dir": "tools/microkit-sdk/downloads",
            "sel4": true
          },
          "scalarFlags": ["boards", "configs", "tool-target-triple", "toolchain-dir", "toolchain-prefix-aarch64"]
        }
      }
    }
  }
}
