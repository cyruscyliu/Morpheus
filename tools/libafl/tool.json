{
  "name": "libafl",
  "runtime": null,
  "cli-contract": "fetch,patch,build,exec,inspect",
  "config": {
    "fields": {
      "mode": {
        "aliases": [
          "mode"
        ]
      },
      "source": {
        "aliases": [
          "source"
        ],
        "path": true
      },
      "seed-dir": {
        "aliases": [
          "seed-dir",
          "seedDir"
        ],
        "path": true
      },
      "build-version": {
        "aliases": [
          "build-version",
          "buildVersion",
          "git-ref",
          "gitRef"
        ]
      },
      "git-url": {
        "aliases": [
          "git-url",
          "gitUrl"
        ]
      },
      "patch-dir": {
        "aliases": [
          "patch-dir",
          "patchDir"
        ],
        "path": true
      },
      "reuse-build-dir": {
        "aliases": [
          "reuse-build-dir",
          "reuseBuildDir"
        ],
        "boolean": true
      },
      "build-dir-key": {
        "aliases": [
          "build-dir-key",
          "buildDirKey"
        ]
      },
      "cargo-arg": {
        "aliases": [
          "cargo-arg",
          "cargo-args",
          "cargoArgs"
        ],
        "repeatable": true
      },
      "run-dir": {
        "aliases": [
          "run-dir",
          "runDir"
        ],
        "path": true
      },
      "nvirsh-state": {
        "aliases": [
          "nvirsh-state",
          "nvirshState"
        ],
        "path": true
      },
      "detach": {
        "aliases": [
          "detach"
        ],
        "boolean": true
      },
      "artifacts": {
        "aliases": [
          "artifacts"
        ],
        "repeatable": true
      }
    }
  },
  "managed": {
    "schemaVersion": 1,
    "modes": [
      "local"
    ],
    "local": {
      "sourceTemplate": "tools/libafl/builds/{buildDirKey}/source",
      "buildDirTemplate": "tools/libafl/builds/{buildDirKey}/build",
      "installDirTemplate": "tools/libafl/builds/{buildDirKey}/install",
      "execDirTemplate": "tools/libafl/runs/{buildDirKey}",
      "artifacts": {
        "source-dir": {
          "pathTemplate": "tools/libafl/builds/{buildDirKey}/source"
        },
        "crate-dir": {
          "pathTemplate": "tools/libafl/builds/{buildDirKey}/source/crates/libafl_nesting"
        },
        "qemu-bridge-dir": {
          "pathTemplate": "tools/libafl/builds/{buildDirKey}/build/qemu-libafl-bridge"
        },
        "qemu-bridge-lib": {
          "pathTemplate": "tools/libafl/builds/{buildDirKey}/install/lib/libqemu-system-aarch64.so"
        },
        "guest-stub-binary": {
          "pathTemplate": "tools/libafl/builds/{buildDirKey}/install/bin/libafl_nesting_stub"
        },
        "qemu-nesting-fuzzer": {
          "pathTemplate": "tools/libafl/builds/{buildDirKey}/install/bin/qemu_nesting"
        },
        "run-manifest": {
          "pathTemplate": "tools/libafl/runs/{buildDirKey}/manifest.json"
        }
      },
      "commands": {
        "fetch": {
          "requiredFlags": [
            "source"
          ],
          "scalarFlags": [
            "git-url",
            "seed-dir",
            "build-version"
          ],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/fetch.sh",
            "shell": "bash"
          },
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source"
          },
          "result": {
            "successSummary": "fetched managed LibAFL source tree",
            "reusedSummary": "reused managed LibAFL source tree",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{source}"
            },
            "details": {
              "source": "{source}",
              "build_version": {
                "fromFlag": "build-version"
              },
              "git_url": {
                "fromFlag": "git-url"
              }
            }
          }
        },
        "patch": {
          "requiredFlags": [
            "source",
            "patch-dir"
          ],
          "scalarFlags": [
            "patch-dir"
          ],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/patch.sh",
            "shell": "bash"
          },
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source"
          },
          "result": {
            "successSummary": "patched managed LibAFL source tree",
            "reusedSummary": "reused patched managed LibAFL source tree",
            "artifact": {
              "path": "source-dir",
              "locationTemplate": "{source}"
            },
            "details": {
              "source": "{source}",
              "patch_dir": "{patch-dir}",
              "artifacts": [
                {
                  "path": "source-dir",
                  "location": "{source}"
                },
                {
                  "path": "crate-dir",
                  "location": "{source}/crates/libafl_nesting"
                }
              ]
            }
          }
        },
        "build": {
          "requiredFlags": [
            "source",
            "build-dir",
            "install-dir"
          ],
          "scalarFlags": [
            "source",
            "build-dir",
            "install-dir",
            "patch-dir",
            "reuse-build-dir",
            "build-version",
            "git-url",
            "seed-dir"
          ],
          "repeatableFlags": [
            "cargo-arg"
          ],
          "script": {
            "path": "scripts/build.sh",
            "shell": "bash",
            "cwdTemplate": "{build-dir}"
          },
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source",
            "build-dir": "tools/libafl/builds/{buildDirKey}/build",
            "install-dir": "tools/libafl/builds/{buildDirKey}/install"
          },
          "result": {
            "successSummary": "built local libafl_nesting guest stub",
            "reusedSummary": "reused local libafl_nesting guest stub build",
            "artifact": {
              "path": "qemu-nesting-fuzzer",
              "locationTemplate": "{install-dir}/bin/qemu_nesting"
            },
            "details": {
              "source": "{source}",
              "build_dir": "{build-dir}",
              "install_dir": "{install-dir}",
              "artifacts": [
                {
                  "path": "guest-stub-binary",
                  "location": "{install-dir}/bin/libafl_nesting_stub"
                },
                {
                  "path": "qemu-nesting-fuzzer",
                  "location": "{install-dir}/bin/qemu_nesting"
                },
                {
                  "path": "qemu-bridge-dir",
                  "location": "{build-dir}/qemu-libafl-bridge"
                },
                {
                  "path": "qemu-bridge-lib",
                  "location": "{install-dir}/lib/libqemu-system-aarch64.so"
                }
              ]
            }
          }
        },
        "inspect": {
          "requiredFlags": [
            "source"
          ],
          "scalarFlags": [
            "source",
            "build-dir",
            "install-dir",
            "build-version",
            "git-url"
          ],
          "repeatableFlags": [],
          "script": {
            "path": "scripts/inspect.sh",
            "shell": "bash"
          },
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source",
            "build-dir": "tools/libafl/builds/{buildDirKey}/build",
            "install-dir": "tools/libafl/builds/{buildDirKey}/install"
          },
          "result": {
            "successSummary": "inspected managed LibAFL nesting build",
            "artifact": {
              "path": "crate-dir",
              "locationTemplate": "{source}/crates/libafl_nesting"
            }
          }
        },
        "exec": {
          "requiredFlags": [
            "source",
            "run-dir",
            "install-dir",
            "nvirsh-state"
          ],
          "scalarFlags": [
            "source",
            "run-dir",
            "install-dir",
            "nvirsh-state",
            "detach",
            "build-version",
            "build-dir-key"
          ],
          "repeatableFlags": [],
          "pathFlags": {
            "source": "tools/libafl/builds/{buildDirKey}/source",
            "install-dir": "tools/libafl/builds/{buildDirKey}/install",
            "run-dir": "tools/libafl/runs/{buildDirKey}"
          },
          "script": {
            "path": "scripts/exec.sh",
            "shell": "bash",
            "cwdTemplate": "{run-dir}"
          },
          "result": {
            "successSummary": "launched host-side libafl qemu_nesting fuzzer",
            "attachedSuccessSummary": "completed host-side libafl qemu_nesting fuzzer",
            "errorSummary": "host-side libafl qemu_nesting launch failed",
            "artifact": {
              "path": "run-manifest",
              "locationTemplate": "{run-dir}/manifest.json"
            },
            "details": {
              "run_dir": "{run-dir}",
              "manifest": "{run-dir}/manifest.json",
              "nvirsh_state": "{nvirsh-state}"
            }
          }
        }
      }
    }
  }
}
