+#define MORPHEUS_QEMU_INPUT_PATH_ENV "MORPHEUS_QEMU_INPUT_PATH"
+#define MORPHEUS_HP_DMA_EVENT_OFFSET 0x0c0u
+#define MORPHEUS_HP_DMA_ADDR_LO_OFFSET 0x0c4u
+#define MORPHEUS_HP_DMA_ADDR_HI_OFFSET 0x0c8u
+#define MORPHEUS_HP_DMA_EVENT_OPCODE_SHIFT 0u
+#define MORPHEUS_HP_DMA_EVENT_OPCODE_MASK 0x000000ffu
+#define MORPHEUS_HP_DMA_EVENT_DIRECTION_SHIFT 8u
+#define MORPHEUS_HP_DMA_EVENT_DIRECTION_MASK 0x00000300u
+#define MORPHEUS_HP_DMA_EVENT_SIZE_SHIFT 10u
+#define MORPHEUS_HP_DMA_EVENT_SIZE_MASK 0x0003fc00u
+#define MORPHEUS_HP_DMA_EVENT_DIR_FROM_DEVICE 0x2u
+#define MORPHEUS_HP_DMA_EVENT_DIR_BIDIRECTIONAL 0x3u
+
+typedef struct MorpheusVirtIOMMIOFuzzState {
+    bool initialized;
+    bool enabled;
+    uint8_t *data;
+    gsize len;
+    uint64_t cursor;
+    uint32_t dma_addr_lo;
+    uint32_t dma_addr_hi;
+} MorpheusVirtIOMMIOFuzzState;
+
+static MorpheusVirtIOMMIOFuzzState morpheus_virtio_mmio_fuzz;
+
+static void morpheus_virtio_mmio_fuzz_init(void)
+{
+    const char *path = NULL;
+
+    if (morpheus_virtio_mmio_fuzz.initialized) {
+        return;
+    }
+
+    morpheus_virtio_mmio_fuzz.initialized = true;
+    path = g_getenv(MORPHEUS_QEMU_INPUT_PATH_ENV);
+    if (!path || !*path) {
+        return;
+    }
+
+    if (!g_file_get_contents(path, (gchar **)&morpheus_virtio_mmio_fuzz.data,
+                             &morpheus_virtio_mmio_fuzz.len, NULL)) {
+        return;
+    }
+
+    morpheus_virtio_mmio_fuzz.enabled = morpheus_virtio_mmio_fuzz.len > 0;
+}
+
+static bool morpheus_virtio_mmio_should_fuzz(VirtIODevice *vdev)
+{
+    morpheus_virtio_mmio_fuzz_init();
+    return morpheus_virtio_mmio_fuzz.enabled &&
+           vdev &&
+           vdev->device_id == VIRTIO_ID_NET;
+}
+
+static uint64_t morpheus_virtio_mmio_next(unsigned size)
+{
+    uint64_t value = 0;
+    unsigned i;
+
+    if (!morpheus_virtio_mmio_fuzz.len) {
+        return 0;
+    }
+
+    for (i = 0; i < size; i++) {
+        value |= ((uint64_t)morpheus_virtio_mmio_fuzz
+                  .data[morpheus_virtio_mmio_fuzz.cursor %
+                        morpheus_virtio_mmio_fuzz.len]) << (i * 8);
+        morpheus_virtio_mmio_fuzz.cursor++;
+    }
+
+    return value;
+}
+
+static void morpheus_virtio_mmio_next_buf(uint8_t *buf, unsigned len)
+{
+    unsigned i;
+
+    if (!morpheus_virtio_mmio_fuzz.len) {
+        memset(buf, 0, len);
+        return;
+    }
+
+    for (i = 0; i < len; i++) {
+        buf[i] = morpheus_virtio_mmio_fuzz
+                 .data[morpheus_virtio_mmio_fuzz.cursor %
+                       morpheus_virtio_mmio_fuzz.len];
+        morpheus_virtio_mmio_fuzz.cursor++;
+    }
+}
+
+static bool morpheus_virtio_mmio_dma_writable(uint8_t direction)
+{
+    return direction == MORPHEUS_HP_DMA_EVENT_DIR_FROM_DEVICE ||
+           direction == MORPHEUS_HP_DMA_EVENT_DIR_BIDIRECTIONAL;
+}
+
+static uint8_t morpheus_virtio_mmio_dma_event_opcode(uint32_t event)
+{
+    return (event & MORPHEUS_HP_DMA_EVENT_OPCODE_MASK) >>
+           MORPHEUS_HP_DMA_EVENT_OPCODE_SHIFT;
+}
+
+static uint8_t morpheus_virtio_mmio_dma_event_direction(uint32_t event)
+{
+    return (event & MORPHEUS_HP_DMA_EVENT_DIRECTION_MASK) >>
+           MORPHEUS_HP_DMA_EVENT_DIRECTION_SHIFT;
+}
+
+static unsigned morpheus_virtio_mmio_dma_event_len(uint32_t event)
+{
+    return (event & MORPHEUS_HP_DMA_EVENT_SIZE_MASK) >>
+           MORPHEUS_HP_DMA_EVENT_SIZE_SHIFT;
+}
+
+static bool morpheus_virtio_mmio_fuzz_dma_write(hwaddr offset, uint64_t value,
+                                                unsigned size)
+{
+    uint32_t event;
+    uint64_t addr;
+    uint8_t opcode;
+    uint8_t direction;
+    unsigned len;
+    uint8_t *buf;
+    MemTxResult status;
+
+    if (offset == MORPHEUS_HP_DMA_ADDR_LO_OFFSET && size == 4) {
+        morpheus_virtio_mmio_fuzz.dma_addr_lo = (uint32_t)value;
+        return true;
+    }
+    if (offset == MORPHEUS_HP_DMA_ADDR_HI_OFFSET && size == 4) {
+        morpheus_virtio_mmio_fuzz.dma_addr_hi = (uint32_t)value;
+        return true;
+    }
+    if (offset != MORPHEUS_HP_DMA_EVENT_OFFSET || size != 4) {
+        return false;
+    }
+
+    event = (uint32_t)value;
+    opcode = morpheus_virtio_mmio_dma_event_opcode(event);
+    direction = morpheus_virtio_mmio_dma_event_direction(event);
+    len = morpheus_virtio_mmio_dma_event_len(event);
+    addr = ((uint64_t)morpheus_virtio_mmio_fuzz.dma_addr_hi << 32) |
+           morpheus_virtio_mmio_fuzz.dma_addr_lo;
+
+    if (!morpheus_virtio_mmio_dma_writable(direction) || !addr || !len) {
+        trace_virtio_mmio_dma_fuzz(addr, len, event, opcode, direction,
+                                   morpheus_virtio_mmio_fuzz.cursor, -1);
+        return true;
+    }
+
+    buf = g_malloc(len);
+    morpheus_virtio_mmio_next_buf(buf, len);
+    status = address_space_write(&address_space_memory, addr,
+                                 MEMTXATTRS_UNSPECIFIED, buf, len);
+    g_free(buf);
+    trace_virtio_mmio_dma_fuzz(addr, len, event, opcode, direction,
+                               morpheus_virtio_mmio_fuzz.cursor, status);
+    return true;
+}
+
+static uint64_t morpheus_virtio_mmio_fuzz_mix(hwaddr offset, uint64_t base,
+                                              unsigned size, bool keep_nonzero)
+{
+    uint64_t mask = size >= 8 ? UINT64_MAX : ((1ULL << (size * 8)) - 1);
+    uint64_t fuzz = morpheus_virtio_mmio_next(size);
+    uint64_t fuzzed = (base ^ fuzz) & mask;
+
+    if (keep_nonzero && base != 0 && fuzzed == 0) {
+        fuzzed = base & mask;
+    }
+    trace_virtio_mmio_fuzz_read(offset, base, fuzzed, size,
+                                morpheus_virtio_mmio_fuzz.cursor);
+    return fuzzed;
+}
